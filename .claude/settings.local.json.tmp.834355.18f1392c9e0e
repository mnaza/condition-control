{
  "permissions": {
    "allow": [
      "Bash(git init *)",
      "Bash(bd init *)",
      "Bash(python3 -m venv ~/.platformio-venv)",
      "Bash(~/.platformio-venv/bin/pip install *)",
      "Bash(~/.platformio-venv/bin/pio --version)",
      "Bash(bd create *)",
      "Bash(~/.platformio-venv/bin/pio boards *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(bd close *)"
    ]
  }
}
